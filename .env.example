# === Required ===
# Used for embeddings (always) and optionally for the LLM
OPENAI_API_KEY=sk-...

# === LLM ===
# Choose: "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic
# For anthropic: claude-sonnet-4-6, claude-opus-4-7, claude-haiku-4-5-20251001
# For openai:    gpt-4o-mini, gpt-4o
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...

# === Optional: reranking ===
# If empty, rerank step is skipped and top-K from vector search is used directly.
# Reranking noticeably improves citation quality and is highly recommended.
COHERE_API_KEY=

# === Embeddings ===
EMBEDDING_MODEL=text-embedding-3-small

# === Whisper fallback ===
# Model sizes: tiny.en, base.en, small.en, medium.en, large-v3
# small.en is the sweet spot for English content on CPU.
WHISPER_MODEL=small.en

# === Chunking ===
CHUNK_TARGET_CHARS=1000
CHUNK_OVERLAP_CHARS=150

# === Retrieval ===
TOP_K_RETRIEVE=15
TOP_K_RERANK=4

# === Storage ===
CHROMA_PATH=./chroma_db

# === Transcripts ===
# Comma-separated language priority list. First match wins.
# Example for Hindi content with English fallback: hi,en
TRANSCRIPT_LANGUAGES=en
